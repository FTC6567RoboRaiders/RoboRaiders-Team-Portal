rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isApprovedUser() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserDoc().status == 'Approved';
    }

    function isMentorOrCaptain() {
      return isApprovedUser() && getUserDoc().role in ['mentor_captain', 'mentor', 'captain'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Schema Validators
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'schoolEmail', 'schoolId', 'primarySubteam', 'secondarySubteam', 'role', 'status', 'createdAt'])
        && data.keys().size() >= 9 && data.keys().size() <= 11
        && data.id is string && data.id.size() <= 64
        && data.name is string && data.name.size() <= 128
        && data.schoolEmail is string && data.schoolEmail.size() <= 128
        && data.schoolId is string && data.schoolId.size() <= 128
        && data.primarySubteam is string
        && data.secondarySubteam is string
        && data.role is string
        && data.status is string
        && data.createdAt is number;
    }

    function isValidJournal(data) {
      return data.keys().hasAll(['id', 'subteam', 'author', 'date', 'planned', 'accomplished', 'problemsAndSolutions', 'planNextTime', 'images', 'createdAt', 'updatedAt', 'status'])
        && data.id is string
        && data.subteam is string
        && data.author is string
        && data.date is string
        && data.planned is string && data.planned.size() <= 5000
        && data.accomplished is string && data.accomplished.size() <= 5000
        && data.planNextTime is string && data.planNextTime.size() <= 5000
        && data.status in ['Draft', 'Pending Review', 'Approved', 'Needs Revision']
        && data.createdAt is number
        && data.updatedAt is number;
    }

    function isValidTime(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'userEmail', 'subteam', 'date', 'startTime', 'endTime', 'durationHours', 'taskDescription', 'createdAt'])
        && data.id is string
        && data.userId is string
        && data.userName is string
        && data.userEmail is string
        && data.subteam is string
        && data.date is string
        && data.startTime is string
        && data.endTime is string
        && data.durationHours is number
        && data.taskDescription is string && data.taskDescription.size() <= 5000
        && data.createdAt is number;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'column', 'subteam', 'assignedTo', 'priority', 'createdAt', 'updatedAt', 'updatedBy'])
        && data.id is string
        && data.title is string && data.title.size() <= 500
        && data.description is string && data.description.size() <= 5000
        && data.column in ['todo', 'inprogress', 'review', 'done']
        && data.subteam is string
        && data.assignedTo is string
        && data.priority in ['Low', 'Medium', 'High']
        && data.createdAt is number
        && data.updatedAt is number
        && data.updatedBy is string;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'title', 'date', 'location', 'description', 'impactMetrics', 'hoursLogged', 'participants', 'images', 'creatorName', 'creatorEmail', 'createdAt', 'updatedAt', 'updatedBy'])
        && data.id is string
        && data.title is string && data.title.size() <= 500
        && data.location is string && data.location.size() <= 500
        && data.description is string && data.description.size() <= 5000
        && data.impactMetrics is string && data.impactMetrics.size() <= 5000
        && data.hoursLogged is number
        && data.participants is list
        && data.images is list
        && data.creatorName is string
        && data.creatorEmail is string
        && data.createdAt is number
        && data.updatedAt is number
        && data.updatedBy is string;
    }

    function isValidEmail(data) {
      return data.keys().hasAll(['id', 'from', 'to', 'subject', 'body', 'timestamp'])
        && data.id is string
        && data.from is string
        && data.to is string
        && data.subject is string
        && data.body is string
        && data.timestamp is number;
    }

    function isValidXpAdjustment(data) {
      return data.keys().hasAll(['id', 'userId', 'userName', 'userEmail', 'amount', 'reason', 'awardedBy', 'awardedByEmail', 'createdAt'])
        && data.keys().size() == 9
        && data.id is string
        && data.userId is string
        && data.userName is string
        && data.userEmail is string
        && data.amount is number
        && data.reason is string && data.reason.size() <= 5000
        && data.awardedBy is string
        && data.awardedByEmail is string
        && data.createdAt is number;
    }

    function isValidLedgerTransaction(data) {
      return data.keys().hasAll(['id', 'amount', 'type', 'category', 'account', 'fundingSource', 'paidBy', 'description', 'date', 'createdBy', 'createdByEmail', 'createdAt'])
        && data.keys().size() == 12
        && data.id is string
        && data.amount is number
        && data.type in ['income', 'expense']
        && data.category in ['Parts & Hardware', 'Tools & Equipment', 'Travel & Lodging', 'Team Registration', 'Outreach & Marketing', 'Food & Catering', 'Other']
        && data.account in ['Self-Raised Funds', 'School Allocated Budget']
        && data.fundingSource in ['School Direct Payment', "Steve's Credit Card", 'Out-of-Pocket Reimbursement', 'Sponsor/Donation Check', 'Other']
        && data.paidBy is string && data.paidBy.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.date is string
        && data.createdBy is string
        && data.createdByEmail is string
        && data.createdAt is number;
    }

    // Collection Rules
    
    // 1. Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data) && (
        request.resource.data.status == 'Pending' ||
        (request.resource.data.status == 'Approved' && request.resource.data.schoolEmail in ['admin@school.edu', 'mentor@school.edu', 'ftc6567@gmail.com', 'schen@school.edu', 'arivera@school.edu'])
      );
      allow update: if isSignedIn() && (
        isMentorOrCaptain() ||
        (request.auth.uid == userId 
         && isValidUser(request.resource.data)
         && request.resource.data.schoolEmail == resource.data.schoolEmail
         && request.resource.data.role == resource.data.role
         && request.resource.data.status == resource.data.status)
      );
      allow delete: if isMentorOrCaptain();
    }

    // 2. Journal Entries
    match /journalEntries/{entryId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && isValidJournal(request.resource.data) && (request.resource.data.author == getUserDoc().name || request.resource.data.author == request.auth.token.email || isMentorOrCaptain());
      allow update: if isApprovedUser() && (
        isMentorOrCaptain() ||
        ((resource.data.author == getUserDoc().name || resource.data.author == request.auth.token.email)
         && isValidJournal(request.resource.data)
         && request.resource.data.author == resource.data.author
         && (request.resource.data.status in ['Draft', 'Pending Review'] || request.resource.data.status == resource.data.status))
      );
      allow delete: if isMentorOrCaptain();
    }

    // 3. Time Entries
    match /timeEntries/{entryId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && isValidTime(request.resource.data) && (request.resource.data.userEmail == request.auth.token.email || isMentorOrCaptain());
      allow update: if isApprovedUser() && (
        isMentorOrCaptain() ||
        (resource.data.userEmail == request.auth.token.email 
         && isValidTime(request.resource.data)
         && request.resource.data.userEmail == resource.data.userEmail)
      );
      allow delete: if isMentorOrCaptain();
    }

    // 4. Kanban Tasks
    match /kanbanTasks/{taskId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && isValidTask(request.resource.data);
      allow update: if isApprovedUser() && isValidTask(request.resource.data);
      allow delete: if isApprovedUser();
    }

    // 5. Outreach Events
    match /outreachEvents/{eventId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && isValidEvent(request.resource.data);
      allow update: if isApprovedUser() && isValidEvent(request.resource.data);
      allow delete: if isMentorOrCaptain();
    }

    // 6. Dispatched Emails
    match /dispatchedEmails/{emailId} {
      allow read: if true;
      allow create: if isValidEmail(request.resource.data);
      allow update: if isApprovedUser() && isValidEmail(request.resource.data);
      allow delete: if isMentorOrCaptain();
    }
    
    // 7. XP Adjustments
    match /xpAdjustments/{adjId} {
      allow read: if isApprovedUser();
      allow create: if isMentorOrCaptain() && isValidXpAdjustment(request.resource.data);
      allow update: if isMentorOrCaptain() && isValidXpAdjustment(request.resource.data);
      allow delete: if isMentorOrCaptain();
    }

    // 8. Ledger Transactions
    match /ledgerTransactions/{transactionId} {
      allow read: if isApprovedUser();
      allow create: if isApprovedUser() && isValidLedgerTransaction(request.resource.data) && (request.resource.data.createdByEmail == request.auth.token.email || isMentorOrCaptain());
      allow update: if isApprovedUser() && isValidLedgerTransaction(request.resource.data) && (resource.data.createdByEmail == request.auth.token.email || isMentorOrCaptain());
      allow delete: if isMentorOrCaptain();
    }
  }
}
