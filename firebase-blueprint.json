{
  "entities": {
    "UserAccount": {
      "title": "User Account",
      "description": "A student or mentor profile with credentials, team roles, and administrative statuses.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique id for the user profile." },
        "name": { "type": "string", "description": "Full name of the team member or mentor." },
        "schoolEmail": { "type": "string", "description": "Unique school email address." },
        "schoolId": { "type": "string", "description": "Lunch number or private identification serving as access credentials." },
        "primarySubteam": { "type": "string", "description": "Primary subteam assignment." },
        "secondarySubteam": { "type": "string", "description": "Secondary subteam assignment." },
        "role": { "type": "string", "enum": ["member", "mentor_captain", "mentor", "captain"], "description": "Team permission tier." },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"], "description": "Dashboard authorization state." },
        "createdAt": { "type": "number", "format": "utc-millisec", "description": "Creation timestamp in epoch." },
        "leadership": { "type": "string", "description": "Optional leadership title such as Captain or Subteam Leader." }
      },
      "required": ["id", "name", "schoolEmail", "schoolId", "primarySubteam", "secondarySubteam", "role", "status", "createdAt"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "An engineering journal log documenting planned work, accomplishments, issues, and solutions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subteam": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "planned": { "type": "string" },
        "accomplished": { "type": "string" },
        "problemsAndSolutions": { "type": "array" },
        "planNextTime": { "type": "string" },
        "images": { "type": "array" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "status": { "type": "string", "enum": ["Draft", "Pending Review", "Approved", "Needs Revision"] },
        "reviewer": { "type": "string" },
        "reviewNotes": { "type": "string" },
        "reviewedAt": { "type": "number" }
      },
      "required": ["id", "subteam", "author", "date", "planned", "accomplished", "problemsAndSolutions", "planNextTime", "images", "createdAt", "updatedAt", "status"]
    },
    "TimeEntry": {
      "title": "Time Entry",
      "description": "A timesheet log recording physical attendance and work contribution duration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "subteam": { "type": "string" },
        "date": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "durationHours": { "type": "number" },
        "taskDescription": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "userName", "userEmail", "subteam", "date", "startTime", "endTime", "durationHours", "taskDescription", "createdAt"]
    },
    "KanbanTask": {
      "title": "Kanban Task",
      "description": "A task on the engineering kanban board representing design or software development items.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "column": { "type": "string", "enum": ["todo", "inprogress", "review", "done"] },
        "subteam": { "type": "string" },
        "assignedTo": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "title", "description", "column", "subteam", "assignedTo", "priority", "createdAt", "updatedAt", "updatedBy"]
    },
    "OutreachEvent": {
      "title": "Outreach Event",
      "description": "A community event log containing metrics, descriptions, and structural listings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "impactMetrics": { "type": "string" },
        "hoursLogged": { "type": "number" },
        "participants": { "type": "array" },
        "images": { "type": "array" },
        "creatorName": { "type": "string" },
        "creatorEmail": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "title", "date", "location", "description", "impactMetrics", "hoursLogged", "participants", "images", "creatorName", "creatorEmail", "createdAt", "updatedAt", "updatedBy"]
    },
    "DispatchedEmail": {
      "title": "Dispatched Email",
      "description": "A log of simulated email notifications dispatched to users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "from", "to", "subject", "body", "timestamp"]
    },
    "XPAdjustment": {
      "title": "XP Adjustment",
      "description": "Manual high-performance rewards or correction logs issued by mentors/captains.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "awardedBy": { "type": "string" },
        "awardedByEmail": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "userName", "userEmail", "amount", "reason", "awardedBy", "awardedByEmail", "createdAt"]
    },
    "PendingSystemNotification": {
      "title": "Pending System Notification",
      "description": "A buffered notification of a task update or journal entry awaiting consolidated digest processing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["journal", "task"] },
        "title": { "type": "string" },
        "details": { "type": "string" },
        "authorName": { "type": "string" },
        "subteam": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "type", "title", "details", "authorName", "subteam", "createdAt"]
    },
    "LedgerTransaction": {
      "title": "Ledger Transaction",
      "description": "A financial transaction tracking spending or budget allocations for the team.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string", "enum": ["Parts & Hardware", "Tools & Equipment", "Travel & Lodging", "Team Registration", "Outreach & Marketing", "Food & Catering", "Other"] },
        "account": { "type": "string", "enum": ["Self-Raised Funds", "School Allocated Budget"] },
        "fundingSource": { "type": "string", "enum": ["School Direct Payment", "Steve's Credit Card", "Out-of-Pocket Reimbursement", "Sponsor/Donation Check", "Other"] },
        "paidBy": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdByEmail": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "amount", "type", "category", "account", "fundingSource", "paidBy", "description", "date", "createdBy", "createdByEmail", "createdAt"]
    },
    "SystemSetting": {
      "title": "System Setting",
      "description": "A global configuration or seeding state setting flag.",
      "type": "object",
      "properties": {
        "journals_seeded": { "type": "boolean" },
        "time_seeded": { "type": "boolean" },
        "kanban_seeded": { "type": "boolean" },
        "outreach_seeded": { "type": "boolean" },
        "ledger_seeded": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "systemSettings/{settingId}": {
      "schema": "SystemSetting",
      "description": "Global settings for tracking if database collections have been initialized with demo data."
    },
    "users/{userId}": {
      "schema": "UserAccount",
      "description": "User credentials, access requests, and configuration records."
    },
    "ledgerTransactions/{transactionId}": {
      "schema": "LedgerTransaction",
      "description": "Financial ledger of team expenditures and budget sources."
    },
    "journalEntries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Individual technical engineering notebook journals."
    },
    "timeEntries/{entryId}": {
      "schema": "TimeEntry",
      "description": "Laboratory check-in timesheet records."
    },
    "kanbanTasks/{taskId}": {
      "schema": "KanbanTask",
      "description": "Active tasks tracked on the project workflow Kanban board."
    },
    "outreachEvents/{eventId}": {
      "schema": "OutreachEvent",
      "description": "Outreach community events, participants, and logged impact."
    },
    "dispatchedEmails/{emailId}": {
      "schema": "DispatchedEmail",
      "description": "Simulated system outbox notification dispatch logs."
    },
    "xpAdjustments/{adjId}": {
      "schema": "XPAdjustment",
      "description": "Manual XP increments or deductions issued by mentors/captains."
    },
    "pendingNotifications/{notifId}": {
      "schema": "PendingSystemNotification",
      "description": "Queued notification alerts that are waiting to be processed in mentor digests."
    }
  }
}
